#!/usr/bin/env bash
set -Eeuo pipefail

readonly VERSION="1.2.0"
readonly PROGRAM="smtp-egress-audit"

: "${LOG_ROOT:=/var/log/smtp-egress-audit}"
: "${SMTP_PORT:=25}"
: "${SINCE:=24 hours ago}"
: "${SAMPLE_INTERVAL:=1}"
: "${ACTIVE_THRESHOLD:=10}"
: "${INTERFACE:=auto}"
: "${RESOLVE_HOSTNAMES:=1}"

RUN_DIR=""
REPORT_FILE=""
TCPDUMP_PID=""
BPF_PID=""
STOP_REQUESTED=0
CAPTURE_STATUS="not-started"
CAPTURE_PROCESS_SEEN=0
SOCKET_CAPTURE_STATUS="not-checked"
PEAK_ACTIVE=0

have() { command -v "$1" >/dev/null 2>&1; }
note() { printf '%s\n' "$*"; }
warn() { printf 'WARNING: %s\n' "$*" >&2; }
heading() { printf '\n== %s ==\n' "$*"; }

usage() {
    cat <<'EOF'
Usage:
  smtp-egress-audit
  smtp-egress-audit interactive
  smtp-egress-audit audit
  smtp-egress-audit report
  smtp-egress-audit watch [seconds]
  smtp-egress-audit monitor
  smtp-egress-audit --help
  smtp-egress-audit --version

Read-only audit and monitoring of outbound SMTP connections.

Run without arguments in a terminal to open the interactive provider-alert
assistant. Existing commands remain suitable for automation and systemd.

Environment:
  LOG_ROOT=/var/log/smtp-egress-audit  SMTP_PORT=25
  SINCE="24 hours ago"                 SAMPLE_INTERVAL=1
  ACTIVE_THRESHOLD=10                 INTERFACE=auto
  RESOLVE_HOSTNAMES=1
EOF
}

die() { printf 'ERROR: %s\n' "$*" >&2; exit 2; }
is_uint() { [[ "$1" =~ ^(0|[1-9][0-9]*)$ ]]; }
is_positive_number() { [[ "$1" =~ ^([0-9]+)([.][0-9]+)?$ ]] && awk -v n="$1" 'BEGIN { exit !(n > 0) }'; }

validate_environment() {
    if ! is_uint "$SMTP_PORT" || (( SMTP_PORT < 1 || SMTP_PORT > 65535 )); then
        die "SMTP_PORT must be a decimal integer from 1 to 65535 without leading zeroes"
    fi
    is_positive_number "$SAMPLE_INTERVAL" || die "SAMPLE_INTERVAL must be a positive number"
    is_uint "$ACTIVE_THRESHOLD" || die "ACTIVE_THRESHOLD must be a non-negative decimal integer without leading zeroes"
    [[ "$RESOLVE_HOSTNAMES" == 0 || "$RESOLVE_HOSTNAMES" == 1 ]] || die "RESOLVE_HOSTNAMES must be 0 or 1"
    [[ -n "$SINCE" && "$SINCE" != *$'\n'* ]] || die "SINCE must be a non-empty single-line value"
    [[ "$INTERFACE" =~ ^[[:alnum:]_.:@-]+$ ]] || die "INTERFACE contains invalid characters"
    [[ "$LOG_ROOT" == /* && "$LOG_ROOT" != / && "$LOG_ROOT" != *$'\n'* ]] || die "LOG_ROOT must be an absolute path other than /"
}

validate_duration() {
    if ! is_uint "$1" || (( $1 < 1 || $1 > 604800 )); then
        die "watch duration must be a decimal integer from 1 to 604800 seconds without leading zeroes"
    fi
}

tcpdump_filter() {
    local port="${1:-$SMTP_PORT}"
    if ! is_uint "$port" || (( port < 1 || port > 65535 )); then return 2; fi
    printf 'tcp dst port %s and (tcp[tcpflags] & tcp-syn != 0)\n' "$port"
}

redact_sensitive() {
    sed -E \
        -e '/(^|[^[:alnum:]_])(pass(word)?|secret|token|api[_-]?key|private[_-]?key)[^=]*=/I s#=.*#= [REDACTED]#' \
        -e 's#(://[^/@:[:space:]]+):[^/@[:space:]]+@#\1:[REDACTED]@#g'
}

redact_postconf() {
    awk '
        BEGIN { IGNORECASE=1 }
        /^[[:space:]]*#/ { print; next }
        /^[^=]*(password_maps|password|secret|token|private_key)[^=]*=/ {
            key=$0; sub(/[[:space:]]*=.*/, "", key); print key " = configured"; next
        }
        { gsub(/:\/\/[^\/@:[:space:]]+:[^\/@[:space:]]+@/, "://[REDACTED]:[REDACTED]@"); print }
    '
}

count_postfix_status() { awk -v s="$1" 'index($0, "status=" s) { n++ } END { print n+0 }'; }
extract_sasl_usernames() {
    sed -nE 's/.*sasl_username=([^,[:space:]]+).*/\1/p' | sort | uniq -c | sort -nr
}
extract_smtp_auth() {
    sed -nE 's/.*client=([^[]+)\[([0-9A-Fa-f:.]+)\].*sasl_method=([^,]+), sasl_username=([^,[:space:]]+).*/\4 \2 \1 \3/p'
}
extract_ssh_success() {
    sed -nE 's/.*Accepted (publickey|password|keyboard-interactive[^ ]*) for ([^ ]+) from ([0-9A-Fa-f:.]+).*/\2 \3 \1/p'
}
extract_dovecot_success() {
    sed -nE 's/.*dovecot: ([^(: ]+).*Login:.*user=<([^>]*)>.*rip=([^, >]+).*/\2 \3 \1/p'
}
postqueue_count() {
    awk '
      /Mail queue is empty/ { empty=1 }
      /^[[:alnum:]]+[*!]?[[:space:]]+[0-9]+[[:space:]]/ { n++ }
      END { if (empty) print 0; else print n+0 }
    '
}

watch_duration_for_choice() {
    case "$1" in
        s|skip) printf '0\n' ;;
        1) printf '60\n' ;;
        2) printf '300\n' ;;
        3|'') printf '600\n' ;;
        4) printf '1800\n' ;;
        *) return 1 ;;
    esac
}

history_window_for_choice() {
    case "$1" in
        1) printf '1 hour ago\n' ;;
        2) printf '6 hours ago\n' ;;
        3|'') printf '24 hours ago\n' ;;
        4) printf '7 days ago\n' ;;
        *) return 1 ;;
    esac
}

is_mta_process() {
    case "${1,,}" in
        smtp|smtp-*|postfix|postfix-*|qmgr|pickup|cleanup|anvil|bounce|defer|flush|lmtp|local|pipe|proxymap|scache|tlsmgr|trivial-rewrite|verify|virtual|sendmail|exim|exim4) return 0 ;;
        *) return 1 ;;
    esac
}

classify_incident() {
    local syn_count="$1" capture_status="$2" socket_rows="$3" mta_rows="$4" other_rows="$5"
    local sent_count="$6" deferred_count="$7" queue_count="$8"
    local traffic_observed=0
    (( syn_count > 0 || socket_rows > 0 || mta_rows > 0 || other_rows > 0 )) && traffic_observed=1

    if (( other_rows > 0 )); then
        printf 'NON_MTA_PROCESS\n'
    elif (( traffic_observed && mta_rows > 0 && deferred_count > 0 && deferred_count > sent_count && queue_count > 0 )); then
        printf 'RETRY_STORM\n'
    elif (( traffic_observed )); then
        if (( mta_rows > 0 )); then
            printf 'MAIL_ACTIVITY\n'
        else
            printf 'UNKNOWN_OWNER\n'
        fi
    elif [[ "$capture_status" != ready ]]; then
        printf 'LIMITED_VISIBILITY\n'
    else
        printf 'QUIET\n'
    fi
}

interactive_available() { [[ -t 0 && -t 1 ]]; }

running_as_root() {
    local effective_uid="${EUID:-}"
    [[ -n "$effective_uid" ]] || effective_uid="$(id -u)"
    (( effective_uid == 0 ))
}

count_socket_rows() { awk 'NF >= 5 && $1 !~ /^--/ && $4 ~ /:/ && $5 ~ /:/ {n++} END{print n+0}'; }

format_duration() {
    case "$1" in
        0) printf 'skipped\n' ;;
        60) printf '1 min\n' ;;
        300) printf '5 min\n' ;;
        600) printf '10 min\n' ;;
        1800) printf '30 min\n' ;;
        *) printf '%ss\n' "$1" ;;
    esac
}

check_socket_capture() {
    if ! have ss; then
        SOCKET_CAPTURE_STATUS="missing"
    elif ss -Htanp >/dev/null 2>"$RUN_DIR/ss.stderr"; then
        SOCKET_CAPTURE_STATUS="ready"
    else
        SOCKET_CAPTURE_STATUS="failed"
    fi
}

prompt_incident_port() {
    local value
    while true; do
        printf 'Destination SMTP port [25]: ' >&2
        if ! IFS= read -r value; then return 1; fi
        case "${value,,}" in q|quit|в|выход) return 2 ;; esac
        value="${value:-25}"
        if is_uint "$value" && (( value >= 1 && value <= 65535 )); then
            printf '%s\n' "$value"
            return 0
        fi
        warn "enter a port from 1 to 65535"
    done
}

prompt_watch_duration() {
    local choice duration
    while true; do
        note "Observation time:" >&2
        note "  1) 1 minute   2) 5 minutes   3) 10 minutes (recommended)   4) 30 minutes   s) skip" >&2
        printf 'Choice [3]: ' >&2
        if ! IFS= read -r choice; then return 1; fi
        case "${choice,,}" in q|quit|в|выход) return 2 ;; esac
        if duration="$(watch_duration_for_choice "$choice")"; then
            printf '%s\n' "$duration"
            return 0
        fi
        warn "choose 1, 2, 3, 4, or s"
    done
}

prompt_history_window() {
    local choice window
    while true; do
        note "Log history:" >&2
        note "  1) 1 hour   2) 6 hours   3) 24 hours (recommended)   4) 7 days" >&2
        printf 'Choice [3]: ' >&2
        if ! IFS= read -r choice; then return 1; fi
        case "${choice,,}" in q|quit|в|выход) return 2 ;; esac
        if window="$(history_window_for_choice "$choice")"; then
            printf '%s\n' "$window"
            return 0
        fi
        warn "choose 1, 2, 3, or 4"
    done
}

confirm_investigation() {
    local reply
    printf 'Start read-only investigation? [Y/n]: ' >&2
    if ! IFS= read -r reply; then return 1; fi
    case "${reply,,}" in ''|y|yes|д|да) return 0 ;; *) return 1 ;; esac
}

init_run() {
    local mode="$1" stamp
    umask 077
    stamp="$(date -u +%Y%m%dT%H%M%SZ)"
    RUN_DIR="${LOG_ROOT%/}/${stamp}-${mode}-$$"
    mkdir -p -- "$RUN_DIR" || die "cannot create $RUN_DIR (run as root or set LOG_ROOT)"
    chmod 700 "$RUN_DIR"
    REPORT_FILE="$RUN_DIR/report.txt"
    : >"$REPORT_FILE"
    chmod 600 "$REPORT_FILE"
    exec > >(tee -a "$REPORT_FILE") 2>&1
    note "$PROGRAM $VERSION | mode=$mode | port=$SMTP_PORT | since=$SINCE"
    note "Report directory: $RUN_DIR"
    note "Safety: metadata only; no packet payload or message bodies are captured."
}

run_or_unavailable() {
    local cmd="$1"; shift
    if have "$cmd"; then "$cmd" "$@" 2>&1 || note "$cmd: unavailable or permission denied"; else note "$cmd: not installed"; fi
}

service_summary() {
    local unit
    if ! have systemctl; then note "systemctl: unavailable"; return; fi
    for unit in postfix ssh sshd dovecot fail2ban docker podman; do
        if systemctl cat "$unit" >/dev/null 2>&1; then
            printf '%-12s %s\n' "$unit" "$(systemctl is-active "$unit" 2>/dev/null || true)"
        fi
    done
}

collect_journal_or_file() {
    local kind="$1" output="$2" data="" scope_file="${2}.scope"
    if have journalctl; then
        case "$kind" in
            mail) data="$(journalctl --since "$SINCE" --no-pager -o short-iso -u postfix -u dovecot 2>/dev/null || true)" ;;
            auth) data="$(journalctl --since "$SINCE" --no-pager -o short-iso -u ssh -u sshd -t sudo -t su 2>/dev/null || true)" ;;
        esac
    fi
    local relevant=0
    case "$kind" in
        mail) grep -Eq 'postfix/|dovecot:' <<<"$data" && relevant=1 || true ;;
        auth) grep -Eq 'sshd\[[0-9]+\]: (Accepted|Failed|Invalid)|sudo(\[[0-9]+\])?:|su(\[[0-9]+\])?:' <<<"$data" && relevant=1 || true ;;
    esac
    if (( relevant )); then
        printf '%s\n' "$data" >"$output"
        printf 'bounded\n' >"$scope_file"
        return
    fi
    local candidate
    case "$kind" in
        mail) for candidate in /var/log/mail.log /var/log/maillog; do [[ -r "$candidate" ]] && { cp -- "$candidate" "$output"; printf 'unbounded-file\n' >"$scope_file"; return; }; done ;;
        auth) for candidate in /var/log/auth.log /var/log/secure; do [[ -r "$candidate" ]] && { cp -- "$candidate" "$output"; printf 'unbounded-file\n' >"$scope_file"; return; }; done ;;
    esac
    : >"$output"
    printf 'unavailable\n' >"$scope_file"
    note "$kind logs: unavailable for SINCE=$SINCE"
}

parse_sshd_port() { awk '$1 == "port" && $2 ~ /^[0-9]+$/ { print $2; exit }'; }

effective_ssh_port() {
    local port=""
    if have sshd; then port="$(sshd -T 2>/dev/null | parse_sshd_port || true)"; fi
    if [[ -z "$port" && -r /etc/ssh/sshd_config ]]; then
        port="$(awk 'tolower($1) == "port" && $2 ~ /^[0-9]+$/ { print $2; exit }' /etc/ssh/sshd_config)"
    fi
    printf '%s\n' "${port:-22}"
}

resolve_ptr() {
    local ip="$1" result=""
    [[ "$RESOLVE_HOSTNAMES" == 1 ]] || { printf '%s' "disabled"; return; }
    [[ "$ip" =~ ^[0-9A-Fa-f:.]+$ ]] || { printf '%s' "invalid-ip"; return; }
    if have getent; then
        if have timeout; then result="$(timeout 2 getent hosts "$ip" 2>/dev/null | awk 'NR==1 {print $2}' || true)";
        else result="$(getent hosts "$ip" 2>/dev/null | awk 'NR==1 {print $2}' || true)"; fi
    fi
    printf '%s' "${result:-unresolved}"
}

print_login_rows_with_ptr() {
    local user ip method
    while read -r user ip method; do
        [[ -n "${user:-}" ]] || continue
        printf '%s user=%s ip=%s ptr=%s method=%s\n' "login" "$user" "$ip" "$(resolve_ptr "$ip")" "$method"
    done
}

postfix_report() {
    local log="$1" queue_file="$RUN_DIR/postqueue.txt" queue_status="$RUN_DIR/postqueue.status"
    heading "Postfix delivery summary"
    printf 'status=sent:     %s\n' "$(count_postfix_status sent <"$log")"
    printf 'status=deferred: %s\n' "$(count_postfix_status deferred <"$log")"
    printf 'status=bounced:  %s\n' "$(count_postfix_status bounced <"$log")"
    printf 'queued messages: %s\n' "$(awk '/postfix\/(smtpd|pickup).*: [A-F0-9]+: (client=|uid=)/ {n++} END{print n+0}' "$log")"

    heading "Postfix queue"
    if have postqueue; then
        if postqueue -p >"$queue_file" 2>&1; then
            printf 'ready\n' >"$queue_status"
            cat "$queue_file"
            printf 'Queue entries counted: %s\n' "$(postqueue_count <"$queue_file")"
        else
            printf 'failed\n' >"$queue_status"
            cat "$queue_file"
            note "Postfix queue: unavailable or permission denied"
        fi
    else
        printf 'missing\n' >"$queue_status"
        note "postqueue: not installed"
    fi

    heading "Recent delivery events (metadata only)"
    awk '/postfix\/smtp.*status=(sent|deferred|bounced)/ { print }' "$log" | tail -n 30 || true

    heading "Top recipient domains"
    sed -nE 's/.*to=<[^@>]+@([^>]+)>.*/\1/p' "$log" | tr '[:upper:]' '[:lower:]' | sort | uniq -c | sort -nr | head -20 || true

    heading "Outbound relay endpoints"
    sed -nE 's/.* relay=([^,[:space:]]+).*/\1/p' "$log" | sort | uniq -c | sort -nr | head -20 || true

    heading "Authenticated SMTP users"
    extract_sasl_usernames <"$log" | head -30 || true

    heading "SMTP client hostname and IP"
    sed -nE 's/.*client=([^,]+).*/\1/p' "$log" | sort | uniq -c | sort -nr | head -30 || true

    heading "Rejected relay attempts"
    grep -F 'Relay access denied' "$log" | tail -30 || true
    printf 'Rejected relay attempts: %s\n' "$(grep -Fc 'Relay access denied' "$log" || true)"

    heading "SASL authentication failures"
    grep -Ei 'SASL.*authentication failed|authentication failure' "$log" | tail -30 || true

    heading "Postfix status and processes"
    service_summary | grep -E '^postfix|^dovecot' || true
    if have pgrep; then pgrep -a -f '[p]ostfix/(master|smtp|smtpd|qmgr|pickup)|/usr/lib/[p]ostfix|/usr/libexec/[p]ostfix' || note "No Postfix processes observed"; else note "pgrep: not installed"; fi

    heading "Active TCP connections to destination port $SMTP_PORT"
    snapshot_ss

    heading "Non-default Postfix configuration (secrets redacted)"
    if have postconf; then postconf -n 2>&1 | redact_postconf || note "postconf: unavailable or permission denied"; else note "postconf: not installed"; fi
}

linux_login_report() {
    local log="$1" ssh_port
    ssh_port="$(effective_ssh_port)"
    heading "Current users"
    run_or_unavailable who
    run_or_unavailable w

    heading "Login history"
    run_or_unavailable last -n 30
    run_or_unavailable lastlog

    heading "Established SSH connections"
    note "SSH port: $ssh_port"
    if have ss; then ss -Htnp state established 2>&1 | awk -v suffix=":$ssh_port" 'index($4, suffix) == length($4)-length(suffix)+1 || index($5, suffix) == length($5)-length(suffix)+1 {print}' || note "ss: unavailable or permission denied"; else note "ss: not installed"; fi

    heading "Effective SSH server settings"
    if have sshd; then sshd -T 2>&1 | awk '$1=="port" || $1=="permitrootlogin" || $1=="passwordauthentication"' || note "sshd: unavailable or configuration invalid"; else note "sshd: not installed"; fi

    heading "Successful SSH logins"
    extract_ssh_success <"$log" | tee "$RUN_DIR/ssh-success.txt" | tail -30 | print_login_rows_with_ptr || true
    heading "Top failed SSH source IPs"
    sed -nE 's/.*(Failed password|Invalid user).* from ([0-9A-Fa-f:.]+).*/\2/p' "$log" | sort | uniq -c | sort -nr | head -20 || true
    heading "Recent SSH authentication errors"
    grep -Ei 'Failed password|Invalid user|authentication failure' "$log" | tail -30 || true
    heading "sudo and su events"
    grep -Ei '(^|[[:space:]])(sudo|su)(\[[0-9]+\])?:' "$log" | tail -30 | redact_sensitive || true

    heading "Fail2ban"
    if have fail2ban-client; then fail2ban-client status 2>&1 || true; fail2ban-client status sshd 2>&1 || note "Fail2ban sshd jail unavailable"; else note "fail2ban-client: not installed"; fi
}

mail_login_report() {
    local log="$1"
    heading "Successful SMTP Submission/SASL logins"
    extract_smtp_auth <"$log" | awk '{printf "login user=%s ip=%s client=%s method=%s\n", $1, $2, $3, $4}' | tail -30 || true
    heading "SMTP users and source IPs grouped"
    extract_smtp_auth <"$log" | awk '{print $1, $2}' | sort | uniq -c | sort -nr | head -30 || true

    heading "Successful Dovecot IMAP/POP3 logins"
    extract_dovecot_success <"$log" | tee "$RUN_DIR/dovecot-success.txt" | tail -30 | print_login_rows_with_ptr || true
    heading "Dovecot users and IPs grouped"
    extract_dovecot_success <"$log" | awk '{print $1, $2}' | sort | uniq -c | sort -nr | head -30 || true
    heading "Top failed mail authentication source IPs"
    {
        sed -nE '/auth failed|Authentication failure|Aborted login/I s/.*rip=([^, >]+).*/\1/p' "$log"
        sed -nE '/SASL.*authentication failed/I s/.*\[([0-9A-Fa-f:.]+)\].*/\1/p' "$log"
    } | sort | uniq -c | sort -nr | head -20 || true
    heading "Recent mail authentication errors"
    grep -Ei 'auth failed|Authentication failure|Aborted login|SASL.*authentication failed' "$log" | tail -30 || true
}

snapshot_ss() {
    if ! have ss; then note "ss: not installed"; return; fi
    ss -Htanp 2>&1 | awk -v p="$SMTP_PORT" '
      function port(endpoint, x) { x=endpoint; sub(/^.*]:/, "", x); sub(/^.*:/, "", x); return x }
      port($5) == p { print }
    ' || true
}

system_audit() {
    heading "Host and time"
    printf 'hostname: %s\n' "$(hostname 2>/dev/null || note unavailable)"
    printf 'fqdn: %s\n' "$(hostname -f 2>/dev/null || note unavailable)"
    run_or_unavailable date --iso-8601=seconds
    if have timedatectl; then timedatectl 2>&1 | sed -n '1,8p' || note "timedatectl: unavailable"; else note "timedatectl: not installed"; fi
    run_or_unavailable uptime

    heading "Reboot history"
    if have last; then last reboot -n 20 2>&1 || note "reboot history: unavailable"; else note "last: not installed"; fi
    heading "IP addresses"
    run_or_unavailable ip -brief address
    heading "Routes"
    run_or_unavailable ip route show
    heading "Relevant services"
    service_summary
    heading "Mail transfer agent processes"
    if have pgrep; then pgrep -a -f '([p]ostfix|[e]xim|[s]endmail)' || note "No Postfix, Exim, or Sendmail processes observed"; else note "pgrep: not installed"; fi

    heading "Cron jobs (sensitive assignments redacted)"
    if have crontab; then crontab -l 2>&1 | redact_sensitive || true; else note "crontab: not installed"; fi
    if [[ -d /etc/cron.d ]]; then find /etc/cron.d -maxdepth 1 -type f -printf '%f\n' 2>/dev/null | sort || note "cron.d listing: unavailable"; fi
    heading "Systemd timers"
    run_or_unavailable systemctl list-timers --all --no-pager

    heading "Containers"
    if have docker; then docker ps --no-trunc 2>&1 || note "docker: unavailable or permission denied"; else note "docker: not installed"; fi
    if have podman; then podman ps --no-trunc 2>&1 || note "podman: unavailable or permission denied"; else note "podman: not installed"; fi

    heading "Conntrack entries for destination port $SMTP_PORT"
    if have conntrack; then conntrack -L -p tcp --dport "$SMTP_PORT" 2>&1 || note "conntrack: unavailable or permission denied"; else note "conntrack: not installed"; fi
}

detect_interface() {
    if [[ "$INTERFACE" != auto ]]; then printf '%s\n' "$INTERFACE"; return; fi
    local detected=""
    if have ip; then
        detected="$(ip route show default 2>/dev/null | awk 'NR==1 {for(i=1;i<=NF;i++) if($i=="dev") {print $(i+1); exit}}' || true)"
    fi
    printf '%s\n' "${detected:-any}"
}

tcpdump_supports_direction() { tcpdump --help 2>&1 | grep -Eq -- '(^|[[:space:]])-Q([[:space:]]|,|$)'; }

cleanup_monitor() {
    STOP_REQUESTED=1
    local pid
    for pid in "$TCPDUMP_PID" "$BPF_PID"; do
        [[ -n "$pid" ]] || continue
        kill "$pid" 2>/dev/null || true
        wait "$pid" 2>/dev/null || true
    done
    TCPDUMP_PID=""
    BPF_PID=""
}

request_monitor_stop() { STOP_REQUESTED=1; }

start_capture() {
    local iface="$1" capture="$RUN_DIR/tcpdump-syn.log" filter
    CAPTURE_STATUS="not-started"
    CAPTURE_PROCESS_SEEN=0
    filter="$(tcpdump_filter)"
    : >"$capture"
    if have tcpdump; then
        local -a args=(-l -nn -tt -s 96 -i "$iface")
        if tcpdump_supports_direction; then
            args+=(-Q out)
            note "tcpdump direction filter: -Q out"
        else
            local addresses="" address source_filter=""
            if have ip; then
                if [[ "$iface" == any ]]; then
                    addresses="$(ip -o address show scope global 2>/dev/null | awk '{sub(/\/.*/, "", $4); print $4}' || true)"
                else
                    addresses="$(ip -o address show dev "$iface" scope global 2>/dev/null | awk '{sub(/\/.*/, "", $4); print $4}' || true)"
                fi
            fi
            while read -r address; do
                [[ "$address" =~ ^[0-9A-Fa-f:.]+$ ]] || continue
                [[ -n "$source_filter" ]] && source_filter+=" or "
                source_filter+="src host $address"
            done <<<"$addresses"
            if [[ -z "$source_filter" ]]; then
                warn "tcpdump lacks -Q out and no local source addresses were found; refusing ambiguous capture"
                CAPTURE_STATUS="direction-unavailable"
            else
                filter="$filter and ($source_filter)"
                note "tcpdump -Q out unsupported; local source-address BPF enforces outbound direction"
            fi
        fi
        if tcpdump_supports_direction || [[ "$filter" == *'src host '* ]]; then
            note "tcpdump interface: $iface"
            note "BPF: $filter"
            tcpdump "${args[@]}" "$filter" >"$capture" 2>"$RUN_DIR/tcpdump.stderr" &
            TCPDUMP_PID=$!
            CAPTURE_STATUS="started"
        fi
    else
        note "tcpdump: not installed; SYN capture unavailable"
        CAPTURE_STATUS="missing"
    fi

    if have tcpconnect-bpfcc; then
        note "tcpconnect-bpfcc: enabled as supplemental process attribution"
        tcpconnect-bpfcc -P "$SMTP_PORT" >"$RUN_DIR/tcpconnect-bpfcc.log" 2>"$RUN_DIR/tcpconnect-bpfcc.stderr" &
        BPF_PID=$!
    else
        note "tcpconnect-bpfcc: not installed (optional)"
    fi
}

monitor_capture_status() {
    case "$CAPTURE_STATUS" in
        started)
            if (( CAPTURE_PROCESS_SEEN == 0 )) \
                || [[ ! -f "$RUN_DIR/tcpdump-syn.log" ]] \
                || { [[ -s "$RUN_DIR/tcpdump.stderr" ]] \
                    && grep -Eqi 'permission denied|operation not permitted|no such device|syntax error|can.t parse|cannot open|failed|fatal|unknown data link|not supported' "$RUN_DIR/tcpdump.stderr"; }; then
                printf 'failed\n'
            else
                printf 'ready\n'
            fi
            ;;
        *) printf '%s\n' "$CAPTURE_STATUS" ;;
    esac
}

observed_socket_processes() {
    local snapshots="$RUN_DIR/ss-snapshots.log"
    {
        if [[ -s "$RUN_DIR/initial-sockets.log" ]]; then
            sed -nE 's/.*users:\(\("([^"]+)".*pid=([0-9]+).*/\1 pid=\2/p' "$RUN_DIR/initial-sockets.log"
        fi
        if [[ -s "$snapshots" ]]; then
            sed -nE 's/.*users:\(\("([^"]+)".*pid=([0-9]+).*/\1 pid=\2/p' "$snapshots"
        fi
        if [[ -s "$RUN_DIR/tcpconnect-bpfcc.log" ]]; then
            awk '$1 ~ /^[0-9]+$/ && $2 ~ /^[[:alnum:]_.:@+-]+$/ {print $2 " pid=" $1}' "$RUN_DIR/tcpconnect-bpfcc.log"
        fi
    } | sort | uniq -c | sort -nr || true
}

monitor_loop() {
    local duration="${1:-}" summary_mode="${2:-full}" iface start now active syn_live threshold_warned=0
    STOP_REQUESTED=0
    TCPDUMP_PID=""
    BPF_PID=""
    PEAK_ACTIVE=0
    iface="$(detect_interface)"; [[ -n "$iface" ]] || iface=any
    trap request_monitor_stop INT TERM
    trap cleanup_monitor EXIT
    start_capture "$iface"
    check_socket_capture
    : >"$RUN_DIR/ss-snapshots.log"
    start=$SECONDS
    while (( STOP_REQUESTED == 0 )); do
        if [[ -n "$TCPDUMP_PID" ]] && kill -0 "$TCPDUMP_PID" 2>/dev/null; then CAPTURE_PROCESS_SEEN=1; fi
        now="$(date --iso-8601=seconds 2>/dev/null || date)"
        if [[ "$SOCKET_CAPTURE_STATUS" == ready ]]; then
            {
                printf -- '-- %s --\n' "$now"
                snapshot_ss
            } >>"$RUN_DIR/ss-snapshots.log"
            active="$(snapshot_ss | awk 'NF {n++} END{print n+0}')"
            (( active > PEAK_ACTIVE )) && PEAK_ACTIVE="$active"
            if (( active > ACTIVE_THRESHOLD && threshold_warned == 0 )); then
                warn "$active active connections to destination port $SMTP_PORT exceed threshold $ACTIVE_THRESHOLD (shown once; peak is reported at the end)"
                threshold_warned=1
            fi
        else
            active=0
        fi
        syn_live="$(awk 'NF {n++} END{print n+0}' "$RUN_DIR/tcpdump-syn.log" 2>/dev/null || echo 0)"
        if [[ "$summary_mode" == compact && -w /dev/tty ]]; then
            printf '\r%s active=%s syn=%s elapsed=%ss' "$now" "$active" "${syn_live:-0}" "$((SECONDS-start))" >/dev/tty
        else
            printf '\r%s active=%s syn=%s elapsed=%ss' "$now" "$active" "${syn_live:-0}" "$((SECONDS-start))"
        fi
        if [[ -n "$duration" ]] && (( SECONDS - start >= duration )); then break; fi
        if ! sleep "$SAMPLE_INTERVAL"; then STOP_REQUESTED=1; fi
    done
    if [[ "$summary_mode" == compact && -w /dev/tty ]]; then printf '\n' >/dev/tty; else printf '\n'; fi
    cleanup_monitor
    trap - INT TERM EXIT
    if [[ "$summary_mode" == full ]]; then
        monitor_summary
    else
        monitor_summary >"$RUN_DIR/network-summary.txt" 2>&1
    fi
}

monitor_summary() {
    local capture="$RUN_DIR/tcpdump-syn.log" processes
    heading "Network monitoring summary"
    if [[ -s "$capture" ]]; then
        printf 'Outbound SYN observed: %s\n' "$(awk 'NF {n++} END{print n+0}' "$capture")"
        note "Destination IP:port counts:"
        awk '/ > / {dest=$5; sub(/:$/, "", dest); print dest}' "$capture" | sort | uniq -c | sort -nr
    else
        note "Outbound SYN observed: 0 (or tcpdump unavailable/insufficient privileges)"
    fi
    note "Observed socket processes:"
    processes="$(observed_socket_processes)"
    if [[ -n "$processes" ]]; then
        printf '%s\n' "$processes"
    else
        note "none"
    fi
    [[ -s "$RUN_DIR/tcpdump.stderr" ]] && { note "tcpdump diagnostics:"; tail -20 "$RUN_DIR/tcpdump.stderr"; } || true
}

run_report() {
    local mail_log="$RUN_DIR/mail.log" auth_log="$RUN_DIR/auth.log"
    collect_journal_or_file mail "$mail_log"
    collect_journal_or_file auth "$auth_log"
    postfix_report "$mail_log"
    linux_login_report "$auth_log"
    mail_login_report "$mail_log"
    heading "Interpretation reminder"
    note "NOQUEUE: reject / Relay access denied normally records a rejected inbound attempt."
    note "postfix/smtp with status=sent records a completed outbound delivery."
    note "sasl_username identifies the authenticated mail account."
}

evidence_coverage() {
    local capture_status="$1" sockets_available="$2" mail_available="$3"
    if [[ "$capture_status" == ready && "$sockets_available" == 1 && "$mail_available" == 1 ]]; then
        printf 'FULL\n'
    elif [[ "$capture_status" == ready || "$sockets_available" == 1 || "$mail_available" == 1 ]]; then
        printf 'PARTIAL\n'
    else
        printf 'MINIMAL\n'
    fi
}

incident_summary() {
    local capture_status syn_count socket_rows mta_rows=0 other_rows=0 sent_count deferred_count bounced_count
    local queue_count=-1 queue_display="unavailable" process_rows process_line coverage verdict label explanation next_step
    local sockets_available=0 mail_available=0 destination_count=0 mail_scope="unknown" queue_status="unknown"
    local classification_deferred=0

    capture_status="$(monitor_capture_status)"
    syn_count="$(awk 'NF {n++} END{print n+0}' "$RUN_DIR/tcpdump-syn.log" 2>/dev/null || echo 0)"
    socket_rows="$({
        count_socket_rows <"$RUN_DIR/initial-sockets.log" 2>/dev/null
        count_socket_rows <"$RUN_DIR/ss-snapshots.log" 2>/dev/null
    } | awk '{n+=$1} END{print n+0}')"
    [[ "$SOCKET_CAPTURE_STATUS" == ready ]] && sockets_available=1
    [[ -r "$RUN_DIR/mail.log.scope" ]] && IFS= read -r mail_scope <"$RUN_DIR/mail.log.scope"
    [[ -s "$RUN_DIR/mail.log" && "$mail_scope" == bounded ]] && mail_available=1

    sent_count="$(count_postfix_status sent <"$RUN_DIR/mail.log" 2>/dev/null || echo 0)"
    deferred_count="$(count_postfix_status deferred <"$RUN_DIR/mail.log" 2>/dev/null || echo 0)"
    bounced_count="$(count_postfix_status bounced <"$RUN_DIR/mail.log" 2>/dev/null || echo 0)"
    [[ -r "$RUN_DIR/postqueue.status" ]] && IFS= read -r queue_status <"$RUN_DIR/postqueue.status"
    if [[ "$queue_status" == ready && -s "$RUN_DIR/postqueue.txt" ]]; then
        queue_count="$(postqueue_count <"$RUN_DIR/postqueue.txt")"
        queue_display="$queue_count"
    fi
    [[ "$mail_scope" == bounded ]] && classification_deferred="$deferred_count"
    if [[ -s "$RUN_DIR/tcpdump-syn.log" ]]; then
        destination_count="$(awk '/ > / {dest=$5; sub(/:$/, "", dest); print dest}' "$RUN_DIR/tcpdump-syn.log" | sort -u | awk 'NF {n++} END{print n+0}')"
    fi

    process_rows="$(observed_socket_processes)"
    while read -r count process_line _; do
        [[ "$count" =~ ^[0-9]+$ && -n "${process_line:-}" ]] || continue
        if is_mta_process "$process_line"; then
            mta_rows=$((mta_rows + count))
        else
            other_rows=$((other_rows + count))
        fi
    done <<<"$process_rows"

    coverage="$(evidence_coverage "$capture_status" "$sockets_available" "$mail_available")"
    verdict="$(classify_incident "$syn_count" "$capture_status" "$socket_rows" "$mta_rows" "$other_rows" "$sent_count" "$classification_deferred" "$queue_count")"
    case "$verdict" in
        NON_MTA_PROCESS)
            label="NON-MAIL PROCESS NEEDS ATTENTION"
            explanation="A process outside the recognized mail transport set owned SMTP sockets. Confirm the application or container immediately."
            next_step="Review the process path, parent process, user, container, and matching timestamps before containment."
            ;;
        RETRY_STORM)
            label="POSSIBLE POSTFIX RETRY ACTIVITY"
            explanation="A recognized mail process was observed and deferred deliveries dominate the selected log window."
            next_step="Inspect deferred reasons, destinations, queue age, and compare the exact interval with the provider alert."
            ;;
        MAIL_ACTIVITY)
            label="MAIL TRAFFIC OBSERVED"
            explanation="A recognized mail process appeared in live socket evidence; short-lived SYN attempts may remain unattributed and expected volume is not proven."
            next_step="Compare destination counts, authenticated users, and provider timestamps with normal server traffic."
            ;;
        UNKNOWN_OWNER)
            label="OUTBOUND SMTP OWNER NOT ATTRIBUTED"
            explanation="SMTP traffic was observed, but the short-lived connection owner was not identified."
            next_step="Repeat a longer watch and install tcpconnect-bpfcc if stronger process attribution is required."
            ;;
        LIMITED_VISIBILITY)
            label="EVIDENCE INCOMPLETE"
            explanation="Packet capture was skipped or unavailable and no live SMTP socket was preserved."
            next_step="Run again as root with tcpdump and ss available, ideally while the provider event is active."
            ;;
        *)
            label="TRAFFIC NOT REPRODUCED"
            explanation="No outbound SMTP connection appeared during this observation window; an earlier event is still possible."
            next_step="Compare the window with the provider timestamp and repeat during the reported activity period."
            ;;
    esac

    {
        heading "Investigation complete"
        printf 'Assessment: %s\n' "$label"
        note "$explanation"
        printf 'Window: logs=%s | live=%s | port=%s\n' "$SINCE" "$(format_duration "${INCIDENT_WATCH_SECONDS:-0}")" "$SMTP_PORT"
        printf 'Network: SYN=%s | peak-active=%s | destinations=%s | capture=%s\n' "$syn_count" "$PEAK_ACTIVE" "$destination_count" "$capture_status"
        if [[ -n "$process_rows" ]]; then
            printf 'Processes: '
            awk 'NR <= 3 {printf "%s%s(%s, samples=%s)", (NR>1 ? "; " : ""), $2, $3, $1} END {if (NR>3) printf "; +%d more", NR-3; print ""}' <<<"$process_rows"
        else
            note "Processes: none attributed"
        fi
        printf 'Postfix: sent=%s | deferred=%s | bounced=%s | queue=%s | log-scope=%s\n' "$sent_count" "$deferred_count" "$bounced_count" "$queue_display" "$mail_scope"
        if [[ "$mail_scope" == unbounded-file ]]; then
            note "Log note: traditional file fallback was not time-bounded; its counts did not affect retry classification."
        fi
        printf 'Coverage: %s\n' "$coverage"
        printf 'Next: %s\n' "$next_step"
        printf 'Private evidence directory: %s\n' "$RUN_DIR"
        note "Safety: no firewall, service, queue, account, or mail configuration was changed."
    } | tee "$RUN_DIR/assessment.txt"
}

interactive_wizard() (
    local port history_window duration
    interactive_available || die "interactive mode requires a terminal; use audit, report, watch, or monitor for automation"
    running_as_root || die "interactive investigation needs root access; rerun: sudo smtp-egress-audit interactive"

    printf '\n%s %s\n' "$PROGRAM" "$VERSION"
    note "Provider SMTP alert investigation"
    note "Read-only checks; only private metadata reports are written."
    note "Enter q at a prompt to cancel."
    printf '\n'

    if ! port="$(prompt_incident_port)"; then note "Cancelled; no report was created."; return 0; fi
    if ! history_window="$(prompt_history_window)"; then note "Cancelled; no report was created."; return 0; fi
    if ! duration="$(prompt_watch_duration)"; then note "Cancelled; no report was created."; return 0; fi

    printf '\nPlan: TCP/%s | logs: %s | live: %s\n' "$port" "$history_window" "$(format_duration "$duration")"
    if ! confirm_investigation; then note "Cancelled; no report was created."; return 0; fi

    SMTP_PORT="$port"
    SINCE="$history_window"
    INCIDENT_WATCH_SECONDS="$duration"
    validate_environment
    init_run incident
    check_socket_capture
    if [[ "$SOCKET_CAPTURE_STATUS" == ready ]]; then snapshot_ss >"$RUN_DIR/initial-sockets.log" 2>&1 || true; else : >"$RUN_DIR/initial-sockets.log"; fi

    if (( duration > 0 )); then
        note "[1/3] Capturing volatile network state on TCP/$SMTP_PORT"
        note "Press Ctrl+C to finish observation early and continue building the report."
        monitor_loop "$duration" compact
        note "[1/3] Network observation complete."
    else
        CAPTURE_STATUS="skipped"
        PEAK_ACTIVE=0
        : >"$RUN_DIR/tcpdump-syn.log"
        : >"$RUN_DIR/ss-snapshots.log"
        note "[1/3] Live capture skipped; an immediate socket snapshot was saved."
    fi

    trap 'warn "Collection interrupted. Partial evidence: $RUN_DIR"; exit 130' INT TERM
    note "[2/3] Preserving system context..."
    system_audit >"$RUN_DIR/system-audit.txt" 2>&1
    note "[2/3] System context saved."
    note "[3/3] Reading Postfix and login history..."
    run_report >"$RUN_DIR/evidence-report.txt" 2>&1
    note "[3/3] Historical evidence saved."
    incident_summary
    trap - INT TERM
)

main() {
    umask 077
    validate_environment
    if (( $# == 0 )); then
        if interactive_available; then interactive_wizard; return; fi
        usage
        exit 2
    fi
    case "$1" in
        --help|-h) (( $# == 1 )) || die "--help takes no arguments"; usage ;;
        --version|-V) (( $# == 1 )) || die "--version takes no arguments"; printf '%s %s\n' "$PROGRAM" "$VERSION" ;;
        interactive) (( $# == 1 )) || die "interactive takes no arguments"; interactive_wizard ;;
        audit) (( $# == 1 )) || die "audit takes no arguments"; init_run audit; system_audit; run_report ;;
        report) (( $# == 1 )) || die "report takes no arguments"; init_run report; run_report ;;
        watch) (( $# <= 2 )) || die "watch accepts at most one duration"; local duration="${2:-600}"; validate_duration "$duration"; init_run watch; monitor_loop "$duration" ;;
        monitor) (( $# == 1 )) || die "monitor takes no arguments"; init_run monitor; monitor_loop ;;
        *) die "unknown command: $1" ;;
    esac
}

if [[ "${SMTP_EGRESS_AUDIT_LIBRARY:-0}" != 1 ]]; then main "$@"; fi
